# Optional: pre-fill Polymarket credentials for local dev (Vite exposes VITE_* vars).
# Copy to .env.local and fill in your values. Never commit .env.local.

VITE_POLY_ADDRESS=0xYourSignerAddress
VITE_POLY_API_KEY=
VITE_POLY_API_SECRET=
VITE_POLY_API_PASSPHRASE=

# 0 = browser wallet (EOA), 1 = email/Magic login, 2 = Gnosis Safe
VITE_POLY_SIGNATURE_TYPE=1

# Polymarket profile address where USDC is held (often different from signer for email login)
VITE_POLY_FUNDER_ADDRESS=

# Optional: only needed for placing orders or deriving API keys
VITE_POLY_PRIVATE_KEY=
