# Server-side Polymarket credentials — NEVER use VITE_* for these.
# Local: copy to .env.local (loaded by `vercel dev`)
# Production: Vercel → Project → Settings → Environment Variables
# GitHub never sees these values — only this example file is committed.

POLY_ADDRESS=0xYourSignerAddress
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# 0 = browser wallet (EOA), 1 = email/Magic login, 2 = Gnosis Safe
POLY_SIGNATURE_TYPE=1

# Polymarket profile address where USDC is held
POLY_FUNDER_ADDRESS=

# Required on the server to place orders (never expose to the browser)
POLY_PRIVATE_KEY=

# --- Go-live security (recommended for production) ---

# Shared secret: set same value as VITE_APP_API_SECRET below.
# When set, /api/account, /api/orders, and /api/open-orders require Authorization: Bearer <secret>
APP_API_SECRET=

# Kill switch — set to false or 0 to block all trading instantly
POLY_TRADING_ENABLED=true

# Per-order limits (server-enforced)
POLY_MAX_ORDER_SIZE=1000
POLY_MAX_ORDER_COST=500

# Client-side copy of APP_API_SECRET (baked into build — personal dashboards only)
VITE_APP_API_SECRET=
